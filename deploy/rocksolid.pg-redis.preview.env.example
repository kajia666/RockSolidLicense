NODE_ENV=production

POSTGRES_DB=rocksolid
POSTGRES_USER=rocksolid
POSTGRES_PASSWORD=ChangeThisPostgresPassword

RSL_DATA_DIR=/var/lib/rocksolid/data

RSL_HOST=0.0.0.0
RSL_PORT=3000

RSL_TCP_ENABLED=true
RSL_TCP_HOST=0.0.0.0
RSL_TCP_PORT=4000

RSL_MAIN_STORE_DRIVER=postgres
RSL_STATE_STORE_DRIVER=redis
RSL_POSTGRES_URL=postgres://rocksolid:ChangeThisPostgresPassword@postgres:5432/rocksolid
RSL_POSTGRES_PG_MODULE=pg
RSL_POSTGRES_POOL_MAX=10
RSL_REDIS_URL=redis://redis:6379
RSL_REDIS_KEY_PREFIX=rsl

# SQLite is still kept for compatibility shadows / fallback data during preview migration.
RSL_DB_PATH=/var/lib/rocksolid/data/rocksolid-fallback.db
RSL_LICENSE_PRIVATE_KEY_PATH=/var/lib/rocksolid/data/license_private.pem
RSL_LICENSE_PUBLIC_KEY_PATH=/var/lib/rocksolid/data/license_public.pem
RSL_LICENSE_KEYRING_PATH=/var/lib/rocksolid/data/license_keyring.json

RSL_TOKEN_ISSUER=RockSolidLicense
RSL_ADMIN_USERNAME=admin
RSL_ADMIN_PASSWORD=ReplaceThisImmediately
RSL_SERVER_TOKEN_SECRET=ReplaceThisWithARandomSecret
RSL_ADMIN_SESSION_HOURS=12
RSL_DEVELOPER_SESSION_HOURS=24
RSL_REQUEST_SKEW_SECONDS=300
