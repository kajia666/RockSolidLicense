{
  "name": "rock-solid-license",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "pg": "^8.13.1"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:postgres:init": "node scripts/render-postgres-init.mjs",
    "db:postgres:check": "node scripts/render-postgres-init.mjs --check",
    "staging:preflight": "node scripts/staging-preflight.mjs",
    "recovery:preflight": "node scripts/recovery-preflight.mjs",
    "launch:smoke": "node scripts/launch-smoke.mjs",
    "launch:smoke:staging": "node scripts/launch-smoke.mjs --require-https",
    "test": "node --test --test-concurrency=1 --test-isolation=none"
  }
}
