# Copy this file to rocksolid_host_config.env and replace the placeholder values.
RS_PROJECT_CODE=MY_SOFTWARE
RS_PROJECT_NAME=My Software
RS_SDK_APP_ID=app_replace_me
RS_SDK_APP_SECRET=secret_replace_me
RS_APP_SALT=my-product-salt
RS_HTTP_BASE_URL=http://127.0.0.1:3000
RS_HTTP_HOST=127.0.0.1
RS_HTTP_PORT=3000
RS_HTTP_SECURE=false
RS_TCP_ENABLED=true
RS_TCP_HOST=127.0.0.1
RS_TCP_PORT=4000
RS_CLIENT_VERSION=1.0.0
RS_CHANNEL=stable
RS_INCLUDE_TOKEN_KEYS=true
RS_REQUIRE_STARTUP_BOOTSTRAP=true
RS_REQUIRE_LOCAL_TOKEN_VALIDATION=true
RS_REQUIRE_HEARTBEAT_GATE=true
RS_RUN_NETWORK_DEMO=false
RS_DEMO_USERNAME=demo_user
RS_DEMO_PASSWORD=demo_password
RS_DEMO_DEVICE_NAME=Demo Workstation
