$env:NODE_ENV = "production"

$env:RSL_DATA_DIR = "C:\RockSolidLicense\data"

$env:RSL_HOST = "0.0.0.0"
$env:RSL_PORT = "3000"

$env:RSL_TCP_ENABLED = "true"
$env:RSL_TCP_HOST = "0.0.0.0"
$env:RSL_TCP_PORT = "4000"

$env:RSL_MAIN_STORE_DRIVER = "sqlite"
$env:RSL_STATE_STORE_DRIVER = "sqlite"
# $env:RSL_POSTGRES_URL = "postgres://rocksolid:secret@127.0.0.1:5432/rocksolid"
# $env:RSL_REDIS_URL = "redis://127.0.0.1:6379"

$env:RSL_DB_PATH = "C:\RockSolidLicense\data\rocksolid.db"
$env:RSL_LICENSE_PRIVATE_KEY_PATH = "C:\RockSolidLicense\data\license_private.pem"
$env:RSL_LICENSE_PUBLIC_KEY_PATH = "C:\RockSolidLicense\data\license_public.pem"
$env:RSL_LICENSE_KEYRING_PATH = "C:\RockSolidLicense\data\license_keyring.json"

$env:RSL_TOKEN_ISSUER = "RockSolidLicense"
$env:RSL_ADMIN_USERNAME = "admin"
$env:RSL_ADMIN_PASSWORD = "ReplaceThisImmediately"
$env:RSL_SERVER_TOKEN_SECRET = "ReplaceThisWithARandomSecret"
